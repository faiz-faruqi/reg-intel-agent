# Model Provider (Phase 1: openrouter, Phase 2+: bedrock)
MODEL_PROVIDER=openrouter

# OpenRouter credentials — used for both generation and embeddings
OPENROUTER_API_KEY=
# Free model (tested: citations + JSON output pass). Swap to anthropic/claude-sonnet-4.5 for higher quality.
OPENROUTER_MODEL_ID=google/gemma-4-31b-it:free

# Bedrock credentials (Phase 2+)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
BEDROCK_MODEL_ID=anthropic.claude-3-sonnet-20240229-v1:0

# Embedding model (MUST match vector(N) dimension in init-db.sql)
# Phase 1 — OpenRouter text-embedding-3-small: dimension = 1536
# Phase 2 — Bedrock Titan Embeddings V2:        dimension = 1024
# Phase 2 — Bedrock Cohere Embed:               dimension = 1024
# Changing this requires dropping and rebuilding the documents table.
EMBEDDING_MODEL=text-embedding-3-small

# Database
# Option 1: Railway PostgreSQL plugin (demo/production)
DATABASE_URL=postgresql+asyncpg://postgres:<password>@<railway-host>:5432/railway

# Option 2: Neon free tier (local dev)
# DATABASE_URL=postgresql+asyncpg://neon_user:<password>@<neon-host>/neon_db

# LangSmith
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=reg-intel-agent
LANGSMITH_TRACING_V2=true

# GitHub (Phase 2 — Action Agent creates issues on approval)
GITHUB_TOKEN=
GITHUB_REPO=faiz-faruqi/reg-intel-agent

# Application
PORT=8000          # local dev only — Railway overrides this with its own $PORT (8080)
API_PORT=8001      # host port mapped to PORT in docker-compose (change if 8001 is taken)
DEBUG=false
